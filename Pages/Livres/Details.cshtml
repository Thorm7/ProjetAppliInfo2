@page "/Livres/Details/{id:int}"
@model LiberNet.Pages.Livres.DetailsModel

<h1>@Model.Livre?.Titre</h1>

<dl class="row">
    <dt class="col-sm-2">Auteur</dt>
    <dd class="col-sm-10">@Model.Livre?.Auteur</dd>

    <dt class="col-sm-2">Description</dt>
    <dd class="col-sm-10">@Model.Livre?.Description</dd>

    <dt class="col-sm-2">Disponible</dt>
    <dd class="col-sm-10">@(Model.Livre?.Disponible == true ? "Oui" : "Non")</dd>
</dl>

<a href="/Livres">Retour à la liste</a>
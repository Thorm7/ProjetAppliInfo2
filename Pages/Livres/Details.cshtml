@page "/Livres/Details/{id:int}"
@model LiberNet.Pages.Livres.DetailsModel

<h1>@Model.Livre?.Titre</h1>

<dl class="row">
    <dt class="col-sm-2">Auteur</dt>
    <dd class="col-sm-10">@Model.Livre?.Auteur</dd>

    <dt class="col-sm-2">Description</dt>
    <dd class="col-sm-10">@Model.Livre?.Description</dd>

    <dt class="col-sm-2">Disponible</dt>
    <dd class="col-sm-10">@(Model.Livre?.Disponible == true ? "Oui" : "Non")</dd>

    <dt class="col-sm-2">Stock</dt>
    <dd class="col-sm-10">@Model.Livre?.Stock</dd>
</dl>

@if (User.Identity!.IsAuthenticated && Model.Livre?.Stock > 0)
{
    <form method="post" asp-page-handler="Emprunter">
        <input type="hidden" name="id" value="@Model.Livre?.Id" />
        <button type="submit" class="btn btn-primary">Emprunter ce livre</button>
    </form>
}
else if (Model.Livre?.Stock == 0)
{
    <div class="alert alert-warning">Ce livre n'est plus disponible.</div>
}
else
{
    <a href="/Compte/Login" class="btn btn-outline-primary">Connectez-vous pour emprunter</a>
}

<a href="/Livres" class="btn btn-secondary mt-2">Retour à la liste</a>
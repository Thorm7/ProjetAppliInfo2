@page
@model LiberNet.Pages.Compte.EmpruntsModel

<h1>Mes emprunts</h1>

@if (Model.Emprunts.Count == 0)
{
    <div class="alert alert-info">Vous n'avez pas encore d'emprunts.</div>
}
else
{
    <h2>En cours</h2>
    @if (Model.Emprunts.Any(e => e.Statut == "EnCours"))
    {
        <table class="table">
            <thead>
                <tr>
                    <th>Livre</th>
                    <th>Date emprunt</th>
                    <th>Date retour prévue</th>
                    <th>Statut</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var emprunt in Model.Emprunts.Where(e => e.Statut == "EnCours"))
                {
                    <tr>
                        <td>@emprunt.TitreLivre</td>
                        <td>@emprunt.DateEmprunt</td>
                        <td>@emprunt.DateRetour</td>
                        <td><span class="badge bg-warning">En cours</span></td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p class="text-muted">Aucun emprunt en cours.</p>
    }

    <h2 class="mt-4">Rendus</h2>
    @if (Model.Emprunts.Any(e => e.Statut == "Retourne"))
    {
        <table class="table">
            <thead>
                <tr>
                    <th>Livre</th>
                    <th>Date emprunt</th>
                    <th>Date retour</th>
                    <th>Statut</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var emprunt in Model.Emprunts.Where(e => e.Statut == "Retourne"))
                {
                    <tr>
                        <td>@emprunt.TitreLivre</td>
                        <td>@emprunt.DateEmprunt</td>
                        <td>@emprunt.DateRetour</td>
                        <td><span class="badge bg-success">Rendu</span></td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p class="text-muted">Aucun emprunt rendu.</p>
    }
}

<a href="/Livres" class="btn btn-primary mt-3">Voir le catalogue</a>
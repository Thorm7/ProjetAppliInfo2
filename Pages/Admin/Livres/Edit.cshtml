@page "/Admin/Livres/Edit/{id:int}"
@model LiberNet.Pages.Admin.Livres.EditModel

<h1>Modifier un livre</h1>

<form method="post">
    <input type="hidden" asp-for="Livre.Id" />
    <input type="hidden" asp-for="Livre.Auteur" />
    <input type="hidden" asp-for="Livre.Description" />
    <input type="hidden" asp-for="Livre.CategorieId" />

    <div class="mb-3">
        <label asp-for="Livre.Titre" class="form-label">Titre</label>
        <input asp-for="Livre.Titre" class="form-control" />
        <span asp-validation-for="Livre.Titre" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Livre.Auteur" class="form-label">Auteur</label>
        <input asp-for="Livre.Auteur" class="form-control" />
        <span asp-validation-for="Livre.Auteur" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Livre.Stock" class="form-label">Stock</label>
        <input asp-for="Livre.Stock" type="number" class="form-control" />
        <span asp-validation-for="Livre.Stock" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Livre.Disponible" class="form-label">Disponible</label>
        <input asp-for="Livre.Disponible" type="checkbox" class="form-check-input" />
    </div>

    <button type="submit" class="btn btn-primary">Enregistrer</button>
    <a asp-page="Index" class="btn btn-secondary ms-2">Annuler</a>
</form>
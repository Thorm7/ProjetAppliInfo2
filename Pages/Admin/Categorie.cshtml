@page
@model LiberNet.Pages.Admin.Categories.IndexModel

<h1>Gestion des catégories</h1>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<h2>Ajouter une catégorie</h2>
<form method="post" asp-page-handler="Add">
    <div class="mb-3">
        <label asp-for="Categorie.Nom" class="form-label">Nom</label>
        <input asp-for="Categorie.Nom" class="form-control" />
        <span asp-validation-for="Categorie.Nom" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Ajouter</button>
</form>

<h2 class="mt-4">Liste des catégories</h2>
<table class="table">
    <thead>
    <tr>
        <th>Nom</th>
        <th>Actions</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var categorie in Model.Categories)
    {
        <tr>
            <td>@categorie.Nom</td>
            <td>
                <form method="post" asp-page-handler="Delete">
                    <input type="hidden" name="id" value="@categorie.Id" />
                    <button type="submit" class="btn btn-danger btn-sm">Supprimer</button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>